# MongoDB connection (required)
MONGO_URL=mongodb://localhost:27017
DB_NAME=assam_goods_carrier

# Public URL used for QR codes and password-reset links
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# CORS (default: allow all)
CORS_ORIGINS=*

# Bootstrap admin password. Change from the admin UI immediately after first login.
# Once admin password is changed inside the app, this env var is ignored.
ADMIN_PASSWORD=change-me-on-first-login

# Optional: SMTP for password reset emails (can also be configured from the Admin panel)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Assam Goods Carrier <no-reply@example.com>"
